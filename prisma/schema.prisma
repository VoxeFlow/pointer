generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ACCOUNTANT
  EMPLOYEE
}

enum RecordType {
  ENTRY
  BREAK_OUT
  BREAK_IN
  EXIT
}

enum RecordSource {
  PWA
  BROWSER
  MANUAL
}

enum OrganizationStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum OrganizationPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum UpgradeRequestStatus {
  OPEN
  CONTACTED
  CLOSED
}

enum BillingProvider {
  STRIPE
}

enum BillingSubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum TimeAdjustmentRequestStatus {
  OPEN
  REVIEWED
  APPROVED
  REJECTED
}

enum MedicalCertificateStatus {
  SUBMITTED
  REVIEWED
  ACCEPTED
  REJECTED
}

enum PayslipStatus {
  DRAFT
  PUBLISHED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Organization {
  id                        String       @id @default(cuid())
  name                      String
  slug                      String       @unique
  legalName                 String?      @map("legal_name")
  documentNumber            String?      @map("document_number")
  contactEmail              String?      @map("contact_email")
  brandDisplayName          String?      @map("brand_display_name")
  brandLogoUrl              String?      @map("brand_logo_url")
  brandPrimaryColor         String?      @map("brand_primary_color")
  brandAccentColor          String?      @map("brand_accent_color")
  status                    OrganizationStatus @default(TRIAL)
  plan                      OrganizationPlan   @default(STARTER)
  maxEmployees              Int          @default(25) @map("max_employees")
  trialEndsAt               DateTime?    @map("trial_ends_at")
  timezone                  String       @default("America/Sao_Paulo")
  defaultDailyWorkloadMin   Int          @default(480) @map("default_daily_workload_min")
  defaultBreakMinMinutes    Int          @default(60) @map("default_break_min_minutes")
  defaultLateToleranceMin   Int          @default(10) @map("default_late_tolerance_min")
  maxRecordsPerDay          Int          @default(4) @map("max_records_per_day")
  requirePhoto              Boolean      @default(true) @map("require_photo")
  requireGeolocation        Boolean      @default(true) @map("require_geolocation")
  allowGalleryFallback      Boolean      @default(false) @map("allow_gallery_fallback")
  allowExtraordinaryRecords Boolean      @default(false) @map("allow_extraordinary_records")
  enforceWorksiteRadius     Boolean      @default(false) @map("enforce_worksite_radius")
  worksiteAddress           String?      @map("worksite_address")
  worksiteLatitude          Decimal?     @map("worksite_latitude") @db.Decimal(10, 7)
  worksiteLongitude         Decimal?     @map("worksite_longitude") @db.Decimal(10, 7)
  worksiteRadiusMeters      Int          @default(150) @map("worksite_radius_meters")
  worksiteGeocodingProvider String?      @map("worksite_geocoding_provider")
  accountantReportEmail     String?      @map("accountant_report_email")
  monthlyReportEnabled      Boolean      @default(false) @map("monthly_report_enabled")
  lastMonthlyReportSentAt   DateTime?    @map("last_monthly_report_sent_at")
  onboardingCompletedAt     DateTime?    @map("onboarding_completed_at")
  billingProvider           BillingProvider? @map("billing_provider")
  billingEmail              String?      @map("billing_email")
  billingCustomerId         String?      @map("billing_customer_id")
  billingSubscriptionId     String?      @map("billing_subscription_id")
  billingSubscriptionStatus BillingSubscriptionStatus @default(NONE) @map("billing_subscription_status")
  billingCurrentPeriodEndsAt DateTime?   @map("billing_current_period_ends_at")
  billingDelinquentSince    DateTime?    @map("billing_delinquent_since")
  upgradeRequests           UpgradeRequest[]
  billingEvents             BillingEvent[]
  timeAdjustmentRequests    TimeAdjustmentRequest[]
  medicalCertificates       MedicalCertificate[]
  payslips                  Payslip[]
  pushSubscriptions         PushSubscription[]
  pushReminderDeliveries    PushReminderDelivery[]
  users                     User[]
  timeRecords               TimeRecord[]
  auditLogs                 AuditLog[]
  createdAt                 DateTime     @default(now()) @map("created_at")
  updatedAt                 DateTime     @updatedAt @map("updated_at")

  @@map("organizations")
}

model User {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  name           String
  email          String       @unique
  passwordHash   String       @map("password_hash")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  deviceConsentAcceptedAt DateTime? @map("device_consent_accepted_at")
  deviceConsentRevokedAt  DateTime? @map("device_consent_revoked_at")
  deviceConsentVersion    String?   @map("device_consent_version")
  imageConsentAcceptedAt  DateTime? @map("image_consent_accepted_at")
  imageConsentRevokedAt   DateTime? @map("image_consent_revoked_at")
  imageConsentVersion     String?   @map("image_consent_version")
  role           UserRole
  employeeCode   String?      @map("employee_code")
  isActive       Boolean      @default(true) @map("is_active")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timeRecords    TimeRecord[]
  schedule       WorkSchedule?
  actorLogs      AuditLog[]   @relation("AuditActor")
  upgradeRequests UpgradeRequest[] @relation("UpgradeRequester")
  timeAdjustmentRequests TimeAdjustmentRequest[] @relation("AdjustmentRequester")
  reviewedAdjustmentRequests TimeAdjustmentRequest[] @relation("AdjustmentReviewer")
  submittedMedicalCertificates MedicalCertificate[] @relation("MedicalCertificateOwner")
  reviewedMedicalCertificates  MedicalCertificate[] @relation("MedicalCertificateReviewer")
  payslips                     Payslip[]
  payrollProfilePosition       String?      @map("payroll_profile_position")
  payrollBaseSalary            Decimal?     @map("payroll_base_salary") @db.Decimal(12, 2)
  payrollBenefitsAmount        Decimal?     @map("payroll_benefits_amount") @db.Decimal(12, 2)
  payrollDiscountsAmount       Decimal?     @map("payroll_discounts_amount") @db.Decimal(12, 2)
  payrollEarningsTemplateJson  Json?        @map("payroll_earnings_template_json")
  payrollDeductionsTemplateJson Json?       @map("payroll_deductions_template_json")
  pushSubscriptions PushSubscription[]
  pushReminderDeliveries PushReminderDelivery[]
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("users")
}

model TimeRecord {
  id                  String        @id @default(cuid())
  organizationId      String        @map("organization_id")
  userId              String        @map("user_id")
  recordType          RecordType    @map("record_type")
  serverTimestamp     DateTime      @map("server_timestamp")
  clientTimestamp     DateTime?     @map("client_timestamp")
  photoUrl            String        @map("photo_url")
  latitude            Decimal?      @db.Decimal(10, 7)
  longitude           Decimal?      @db.Decimal(10, 7)
  locationAddress     String?       @map("location_address")
  geocodingProvider   String?       @map("geocoding_provider")
  accuracy            Float?
  geoCapturedAt       DateTime?     @map("geo_captured_at")
  source              RecordSource
  deviceInfo          String?       @map("device_info")
  photoMetadataJson   Json?         @map("photo_metadata_json")
  isInconsistent      Boolean       @default(false) @map("is_inconsistent")
  inconsistencyReason String?       @map("inconsistency_reason")
  adjustmentNote      String?       @map("adjustment_note")
  isDisregarded       Boolean       @default(false) @map("is_disregarded")
  disregardedReason   String?       @map("disregarded_reason")
  disregardedAt       DateTime?     @map("disregarded_at")
  supersedesRecordId  String?       @map("supersedes_record_id")
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime      @default(now()) @map("created_at")

  @@index([organizationId, userId, serverTimestamp])
  @@index([organizationId, serverTimestamp])
  @@map("time_records")
}

model WorkSchedule {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  expectedStartTime    String   @map("expected_start_time")
  expectedEndTime      String   @map("expected_end_time")
  breakMinMinutes      Int      @map("break_min_minutes")
  lateToleranceMinutes Int      @map("late_tolerance_minutes")
  dailyWorkloadMinutes Int      @map("daily_workload_minutes")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekdays             WorkScheduleDay[]
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("work_schedules")
}

model WorkScheduleDay {
  id                 String       @id @default(cuid())
  scheduleId         String       @map("schedule_id")
  weekday            Weekday
  isWorkingDay       Boolean      @default(true) @map("is_working_day")
  startTime          String?      @map("start_time")
  endTime            String?      @map("end_time")
  breakMinMinutes    Int          @default(0) @map("break_min_minutes")
  dailyWorkloadMinutes Int        @default(0) @map("daily_workload_minutes")
  schedule           WorkSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@unique([scheduleId, weekday])
  @@index([scheduleId, weekday])
  @@map("work_schedule_days")
}

model AuditLog {
  id             String        @id @default(cuid())
  organizationId String?       @map("organization_id")
  actorUserId    String?       @map("actor_user_id")
  action         String
  targetType     String        @map("target_type")
  targetId       String?       @map("target_id")
  metadataJson   Json?         @map("metadata_json")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser      User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model PushSubscription {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  userId         String       @map("user_id")
  endpoint       String       @unique
  p256dh         String
  auth           String
  userAgent      String?      @map("user_agent")
  isActive       Boolean      @default(true) @map("is_active")
  lastSeenAt     DateTime?    @map("last_seen_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries     PushReminderDelivery[]
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId, userId, isActive])
  @@map("push_subscriptions")
}

model PushReminderDelivery {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  userId         String           @map("user_id")
  subscriptionId String           @map("subscription_id")
  issueCode      String           @map("issue_code")
  issueDateKey   String           @map("issue_date_key")
  sentAt         DateTime         @default(now()) @map("sent_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   PushSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, issueCode, issueDateKey])
  @@index([organizationId, userId, sentAt])
  @@map("push_reminder_deliveries")
}

model UpgradeRequest {
  id             String               @id @default(cuid())
  organizationId String               @map("organization_id")
  requestedById  String?              @map("requested_by_id")
  currentPlan    OrganizationPlan     @map("current_plan")
  desiredPlan    OrganizationPlan     @map("desired_plan")
  status         UpgradeRequestStatus @default(OPEN)
  message        String?
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy    User?                @relation("UpgradeRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  @@index([organizationId, createdAt])
  @@map("upgrade_requests")
}

model BillingEvent {
  id             String          @id @default(cuid())
  organizationId String?         @map("organization_id")
  provider       BillingProvider
  providerEventId String         @unique @map("provider_event_id")
  eventType      String          @map("event_type")
  payloadJson    Json?           @map("payload_json")
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@map("billing_events")
}

model TimeAdjustmentRequest {
  id             String                      @id @default(cuid())
  organizationId String                      @map("organization_id")
  userId         String                      @map("user_id")
  reviewedById   String?                     @map("reviewed_by_id")
  requestedDate  DateTime                    @map("requested_date")
  requestedTime  String?                     @map("requested_time")
  requestedType  RecordType?                 @map("requested_type")
  reason         String
  status         TimeAdjustmentRequestStatus @default(OPEN)
  reviewNote     String?                     @map("review_note")
  organization   Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                        @relation("AdjustmentRequester", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy     User?                       @relation("AdjustmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt      DateTime                    @default(now()) @map("created_at")
  updatedAt      DateTime                    @updatedAt @map("updated_at")

  @@index([organizationId, userId, createdAt])
  @@index([organizationId, status, createdAt])
  @@map("time_adjustment_requests")
}

model MedicalCertificate {
  id               String                   @id @default(cuid())
  organizationId   String                   @map("organization_id")
  userId           String                   @map("user_id")
  reviewedById     String?                  @map("reviewed_by_id")
  issueDate        DateTime?                @map("issue_date")
  startDate        DateTime?                @map("start_date")
  endDate          DateTime?                @map("end_date")
  notes            String?
  fileUrl          String                   @map("file_url")
  originalFileName String                   @map("original_file_name")
  mimeType         String                   @map("mime_type")
  sizeBytes        Int                      @map("size_bytes")
  status           MedicalCertificateStatus @default(SUBMITTED)
  reviewNote       String?                  @map("review_note")
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User                     @relation("MedicalCertificateOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy       User?                    @relation("MedicalCertificateReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")

  @@index([organizationId, userId, createdAt])
  @@index([organizationId, status, createdAt])
  @@map("medical_certificates")
}

model Payslip {
  id               String         @id @default(cuid())
  organizationId   String         @map("organization_id")
  userId           String         @map("user_id")
  competenceMonth  Int            @map("competence_month")
  competenceYear   Int            @map("competence_year")
  referenceLabel   String         @map("reference_label")
  fileUrl          String?        @map("file_url")
  originalFileName String?        @map("original_file_name")
  mimeType         String?        @map("mime_type")
  sizeBytes        Int?           @map("size_bytes")
  grossAmount      Decimal?       @map("gross_amount") @db.Decimal(12, 2)
  benefitsAmount   Decimal?       @map("benefits_amount") @db.Decimal(12, 2)
  discountsAmount  Decimal?       @map("discounts_amount") @db.Decimal(12, 2)
  netAmount        Decimal?       @map("net_amount") @db.Decimal(12, 2)
  earningsBreakdownJson Json?     @map("earnings_breakdown_json")
  deductionsBreakdownJson Json?   @map("deductions_breakdown_json")
  notes            String?
  status           PayslipStatus  @default(DRAFT)
  publishedAt      DateTime?      @map("published_at")
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@unique([organizationId, userId, competenceMonth, competenceYear])
  @@index([organizationId, competenceYear, competenceMonth])
  @@index([organizationId, userId, publishedAt])
  @@map("payslips")
}
